# Training on GPU (H100) — use with Northflank Job or any GPU host.
# Build: docker build -f Dockerfile.train -t robo-replan-train .
# Run:   docker run --gpus all -e MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct robo-replan-train
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Layer order for cache: deps first (change rarely), then code (change often)
COPY pyproject.toml .
RUN pip3 install --no-cache-dir \
    "torch>=2.6.0" --index-url https://download.pytorch.org/whl/cu121 \
    && pip3 install --no-cache-dir \
    "transformers>=4.40" "accelerate>=0.30" "datasets" "trl>=0.15" \
    pydantic numpy "openenv-core==0.2.1" \
    sentencepiece safetensors

COPY server/ server/
COPY train/ train/
COPY scripts/ scripts/

RUN mkdir -p /app/logs /app/outputs

# Defaults: faster run (fewer episodes, fast mode). Override in job env or CMD.
ENV MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
ENV TRAIN_DIFFICULTY=easy
ENV METRICS_JSONL=/app/logs/train_metrics.jsonl
ENV FAST_MODE=1
ENV ORACLE_EPISODES=400
ENV BASELINE_EPISODES=20
ENV FINAL_EVAL_EPISODES=20

CMD ["bash", "-c", "cd /app && python3 train/run_training.py"]
# Or use the wrapper: CMD ["bash", "train/run_h100_1.5b.sh"]
