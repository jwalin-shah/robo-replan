# Training on GPU (H100) — use with Northflank Job or any GPU host.
# Build: docker build -f Dockerfile.train -t robo-replan-train .
# Run:   docker run --gpus all -e MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct robo-replan-train
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps (training stack)
COPY pyproject.toml .
RUN pip3 install --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cu121 \
    && pip3 install --no-cache-dir \
    transformers accelerate datasets trl \
    pydantic numpy "openenv-core==0.2.1" \
    sentencepiece safetensors

# Copy env + training code (run_training imports server)
COPY server/ server/
COPY train/ train/
COPY scripts/ scripts/

ENV MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
ENV TRAIN_DIFFICULTY=easy
ENV METRICS_JSONL=/app/logs/train_metrics.jsonl

RUN mkdir -p /app/logs /app/outputs

# Run training (from repo root so server/ and train/ are on path)
CMD ["bash", "-c", "cd /app && python3 train/run_training.py"]
# Or use the wrapper: CMD ["bash", "train/run_h100_1.5b.sh"]
